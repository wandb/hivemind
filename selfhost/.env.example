# HiveMind self-host configuration.
# `hivemind serve setup` generates the required values; everything else is optional.

# --- Required ---------------------------------------------------------------
# Public hostname of this instance. "localhost" serves plain HTTP for local
# testing; a real domain gets automatic TLS from Caddy (Let's Encrypt).
DOMAIN=localhost
# Full public base URL (scheme + domain). Used for post-login redirects.
EXTERNAL_URL=http://localhost
# Signing secret for HiveMind session tokens. Generate with:
#   openssl rand -hex 32
JWT_SECRET=
# Master key that encrypts instance-wide secrets (GitHub App credentials, and
# any future shared key) stored in ClickHouse so they ride the nightly backup.
# `hivemind serve setup` generates this. Generate manually with:
#   python -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# BACK IT UP: losing it makes those secrets unrecoverable (session data is
# unaffected). Leave unset to keep secrets in this .env / compose instead.
HIVEMIND_SECRET_KEY=

# Host ports Caddy binds. Defaults are 80/443; remap when 80 is taken locally
# or a platform proxy forwards a custom port.
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443

# Per-instance local data directory for GitHub App credentials, screenshots,
# and exports. `hivemind serve setup` writes this under ~/.hivemind/serve/<name>.
#HIVEMIND_SERVE_DATA_DIR=/home/me/.hivemind/serve/default/data

# --- GitHub App (normally configured by the /setup wizard) -------------------
# The first-boot wizard at ${EXTERNAL_URL}/setup creates a GitHub App and
# stores its credentials encrypted in ClickHouse (the instance_secrets table,
# under HIVEMIND_SECRET_KEY) so they're backed up — you don't need to fill
# these in. Set them here only to override the wizard's values, or when
# bringing an app you created manually (see docs/self-hosting.md).
#GITHUB_APP_ID=
#GITHUB_APP_SLUG=
#GITHUB_APP_CLIENT_ID=
#GITHUB_APP_CLIENT_SECRET=
#GITHUB_APP_WEBHOOK_SECRET=
#GITHUB_APP_PRIVATE_KEY=

# --- Access control (optional) -----------------------------------------------
# Restrict login to members of specific GitHub orgs. Comma-separated, case-
# insensitive. Unset (the default) lets any GitHub user sign in (self-serve
# onboarding); "none", "disabled", or "*" also mean unrestricted. The /setup
# wizard prompts for this.
#ALLOWED_GITHUB_ORGS=your-org,another-org

# --- License (optional) ------------------------------------------------------
# Paste the signed license issued from the Hivemind admin console. Unlicensed
# instances keep working and show a "get a license" banner (warn mode).
# Verified offline (Ed25519), so it works airgapped.
#HIVEMIND_LICENSE=
# off | warn (default) | enforce. warn shows banners but never disables
# anything; enforce soft-disables premium features after the grace window.
#LICENSE_ENFORCEMENT_MODE=warn

# --- Telemetry / check-in (optional) -----------------------------------------
# Once a day the instance posts a tiny anonymized check-in to the SaaS:
# install id, server version, install flavor, license state, and (with an
# "aggregate" license) usage counts — never raw session data. It also returns
# the latest server version so the dashboard can flag available updates.
# On by default; opt out with either of:
#HIVEMIND_TELEMETRY=false
#DO_NOT_TRACK=1
# Override where it posts (defaults to the W&B SaaS). Airgapped instances can
# ignore this — the POST just fails silently and the license stays valid.
#LICENSE_TELEMETRY_ENDPOINT=

# --- Object storage (optional) ----------------------------------------------
# Session screenshots and data exports default to the local ./data volume. To
# use object storage instead, `hivemind serve setup` writes the vars below, or
# set them by hand. The s3 provider covers AWS S3, Cloudflare R2, Google Cloud
# Storage (via its S3-interop endpoint), and any S3-compatible store.
#STORAGE_PROVIDER=s3
#S3_BUCKET_NAME=my-hivemind-bucket
# Endpoint for non-AWS stores (leave unset for AWS S3, which derives it from
# the region):
#   Cloudflare R2:  https://<account-id>.r2.cloudflarestorage.com
#   Google Cloud:   https://storage.googleapis.com
#   MinIO / custom: https://minio.example.com
#S3_ENDPOINT_URL=
#AWS_REGION=us-east-1          # use "auto" for Cloudflare R2 and GCS
#AWS_ACCESS_KEY_ID=            # HMAC key for R2/GCS
#AWS_SECRET_ACCESS_KEY=        # HMAC secret for R2/GCS
# Native Google Cloud Storage instead of S3-interop: set STORAGE_PROVIDER=gcs,
# GCS_BUCKET_NAME, mount a service-account JSON, and point
# GOOGLE_APPLICATION_CREDENTIALS at it.
#GCS_BUCKET_NAME=

# --- External / managed ClickHouse (optional) -------------------------------
# By default the stack runs a bundled ClickHouse container. To use an external
# or managed ClickHouse instead (e.g. ClickHouse Cloud — recommended for
# production; it handles backups, upgrades, and scaling), set CLICKHOUSE_HOST
# to anything other than "clickhouse". `hivemind serve` then leaves the bundled
# container out entirely, and the app/worker connect here instead. The database
# named by CLICKHOUSE_DB (below) is created automatically on first boot (the
# credentials need CREATE DATABASE). `hivemind serve setup` writes these when
# you choose external ClickHouse.
#CLICKHOUSE_HOST=abc123.us-east-1.aws.clickhouse.cloud
#CLICKHOUSE_PORT=8443          # managed CH uses 8443 (HTTPS); bundled uses 8123
# Port 8443/443 auto-enables TLS, so managed CH (e.g. ClickHouse Cloud) needs
# nothing here. Only set this to force TLS on a non-standard port.
#CLICKHOUSE_SECURE=true
# Database name (bundled or external). New instances use `hivemind`. If you are
# upgrading an instance created before this default changed, set this to
# `agentstream` so the stack keeps pointing at your existing data.
CLICKHOUSE_DB=hivemind
#CLICKHOUSE_USER=default
#CLICKHOUSE_PASSWORD=

# --- ClickHouse on object storage (experimental) ----------------------------
# Back ClickHouse's table data with the same bucket, keeping a local cache of
# hot data (like ClickHouse Cloud). `hivemind serve setup` sets these when you
# opt in; credentials are reused from AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY.
# IMPORTANT: the local clickhouse_data volume STILL holds the disk metadata
# that maps parts to object keys - keep backing it up; object storage does not
# make the volume disposable. Best enabled on a fresh install; switching an
# existing one requires a manual data move (see docs/self-hosting.md).
#CLICKHOUSE_STORAGE_CONFIG=./clickhouse-storage.xml
#CLICKHOUSE_S3_ENDPOINT=https://my-hivemind-bucket.s3.us-east-1.amazonaws.com/clickhouse/
#CLICKHOUSE_S3_CACHE_SIZE=10Gi

# --- Nightly ClickHouse backups (optional) ----------------------------------
# When object storage is configured, `hivemind serve setup` can enable a
# sidecar that backs ClickHouse up to the same bucket every night (native
# BACKUP ... TO S3, under the clickhouse-backups/ prefix) and prunes backups
# older than the retention window. It is gated behind the `backup` compose
# profile and reuses the AWS_*/S3_* credentials above. To restore, see
# docs/self-hosting.md ("Backups").
#COMPOSE_PROFILES=backup
#CLICKHOUSE_BACKUP_S3_ENDPOINT=https://my-hivemind-bucket.s3.us-east-1.amazonaws.com/clickhouse-backups/
#CLICKHOUSE_BACKUP_RETENTION_DAYS=3
#CLICKHOUSE_BACKUP_HOUR=3                  # UTC hour (0-23) to run the backup
# rclone provider for the prune step: AWS for S3, Other for R2/GCS/MinIO.
#CLICKHOUSE_BACKUP_RCLONE_PROVIDER=AWS

# --- Optional ----------------------------------------------------------------
# Caddy site address. Defaults to EXTERNAL_URL (scheme decides TLS). Set to
# "http://" when an upstream proxy/load balancer terminates TLS — Caddy then
# serves plain HTTP on any host while EXTERNAL_URL stays the public https URL.
#SITE_ADDRESS=http://

# Restrict login to members of these GitHub orgs (comma-separated).
# Unset = anyone with a GitHub account can log in to this instance.
#ALLOWED_GITHUB_ORGS=my-github-org

# --- Worker scaling (optional) -----------------------------------------------
# Two knobs, usable together (see docs/self-hosting.md#scaling-the-worker):
#   WORKER_MAX_IN_FLIGHT — concurrent jobs per worker. Unset auto-sizes from the
#     host CPU count (4x cores, floor 10, cap 32).
#WORKER_MAX_IN_FLIGHT=16
#   WORKER_REPLICAS — number of worker containers, sharing one Redis Streams
#     consumer group; only one runs the leader tasks.
#WORKER_REPLICAS=2

# --- LLM provider (advanced AI features) -------------------------------------
# Insights, PR walkthroughs, personas, session enrichment and fork-context all
# call an LLM. They're bring-your-own-provider and quietly no-op when nothing
# below is set. `hivemind serve setup` can write these for you. Full guide
# (Ollama, W&B/CoreWeave, Bedrock): docs/llm-providers.md.
#
# Default — Anthropic. Just provide a key and you're done:
#ANTHROPIC_API_KEY=
#
# Or point every feature at an OpenAI-compatible endpoint instead. LLM_PROVIDER
# is auto-detected as `openai` once LLM_BASE_URL or LLM_API_KEY is set.
#   Ollama on the host:
#LLM_BASE_URL=http://host.docker.internal:11434/v1
#LLM_MODEL=llama3.3
#   W&B / CoreWeave inference service (OpenAI-compatible):
#LLM_BASE_URL=https://api.inference.wandb.ai/v1
#LLM_API_KEY=<your-wandb-api-key>
#LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
#LLM_EXTRA_HEADERS={"OpenAI-Project": "my-team/my-project"}
#   Generic OpenAI-compatible endpoint:
#LLM_PROVIDER=openai
#LLM_API_KEY=
#LLM_BASE_URL=
#LLM_MODEL=
#
# Or Amazon Bedrock (Anthropic models via the AWS credential chain):
#LLM_PROVIDER=bedrock
#LLM_BEDROCK_REGION=us-east-1
#LLM_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#
# Cheaper model for the short-prompt features (titles, weekly summaries).
# Falls back to LLM_MODEL when unset.
#LLM_SMALL_MODEL=
#
# Per-feature model overrides (optional; each falls back to LLM_MODEL —
# TITLE_EXTRACTION_MODEL and WEEKLY_SUMMARY_MODEL via LLM_SMALL_MODEL first):
#ENRICHMENT_MODEL=
#TITLE_EXTRACTION_MODEL=
#WEEKLY_SUMMARY_MODEL=
#PERSONA_MODEL=
#FORK_CONTEXT_MODEL=
#INSIGHTS_MATCHER_MODEL=

# --- Embeddings (insight clustering + semantic search) -----------------------
# OpenAI-compatible; falls back to OPENAI_API_KEY when the EMBEDDINGS_* vars are
# unset. A replacement model MUST emit 1536-dimensional vectors to match the
# ClickHouse vector index. Set EMBEDDINGS_PROVIDER=none to disable embeddings.
#OPENAI_API_KEY=
#EMBEDDINGS_API_KEY=
#EMBEDDINGS_BASE_URL=
#EMBEDDINGS_MODEL=text-embedding-3-small

# --- Tailscale (optional remote access) --------------------------------------
# Put this instance on your tailnet with an automatic HTTPS certificate, so you
# can reach the dashboard from anywhere without opening a port or buying a
# domain. Configure with `hivemind serve tailscale enable`, not by hand — it
# also flips SITE_ADDRESS to http:// (Tailscale terminates TLS) and points
# EXTERNAL_URL at the node's MagicDNS name. Two modes:
#   host    — reuses Tailscale already running on this host (`tailscale serve`).
#             None of the vars below are needed.
#   sidecar — runs a tailscale/tailscale container (docker-compose.tailscale.yml)
#             that joins your tailnet with its own node identity, using the vars
#             below. No host Tailscale install required.
#
# TAILSCALE_MODE is set by `hivemind serve tailscale enable` (host or sidecar);
# "sidecar" is what makes `hivemind serve up` layer in the sidecar overlay.
#TAILSCALE_MODE=
# Reusable or ephemeral auth key / OAuth client secret from the admin console
# (https://login.tailscale.com/admin/settings/keys). Required for sidecar mode.
#TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxx
# Node name on your tailnet (the host part of <name>.<tailnet>.ts.net).
#TAILSCALE_HOSTNAME=hivemind
# Expose on the public internet via Tailscale Funnel (default: tailnet-only).
#TAILSCALE_FUNNEL=false
# Extra flags for `tailscale up` in the sidecar, e.g. to tag the node:
#TAILSCALE_EXTRA_ARGS=--advertise-tags=tag:hivemind
# Set true on hosts without /dev/net/tun (also remove the devices: entry from
# docker-compose.tailscale.yml). Serve still works in userspace mode.
#TAILSCALE_USERSPACE=false
# Pin the sidecar's Tailscale client image. Defaults to a known-good version;
# tailscale/tailscale:latest and :stable are not reliably stable (see #11204).
#TAILSCALE_VERSION=v1.92.4
