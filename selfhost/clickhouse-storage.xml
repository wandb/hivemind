<clickhouse>
    <!--
      S3-backed storage with a local filesystem cache, enabled by
      `hivemind serve setup` (Object storage -> "Back ClickHouse with object
      storage"). Mirrors ClickHouse Cloud's model: table parts live in the
      bucket while hot data is served from a local cache.

      Endpoint and credentials come from the clickhouse service's environment
      (CLICKHOUSE_S3_* in .env / docker-compose). The local volume still holds
      the disk *metadata* mapping parts to object keys, so the clickhouse_data
      volume remains essential - keep backing it up.
    -->
    <storage_configuration>
        <disks>
            <s3_disk>
                <type>s3</type>
                <endpoint from_env="CLICKHOUSE_S3_ENDPOINT"/>
                <access_key_id from_env="CLICKHOUSE_S3_ACCESS_KEY_ID"/>
                <secret_access_key from_env="CLICKHOUSE_S3_SECRET_ACCESS_KEY"/>
                <metadata_path>/var/lib/clickhouse/disks/s3_disk/</metadata_path>
            </s3_disk>
            <s3_cache>
                <type>cache</type>
                <disk>s3_disk</disk>
                <path>/var/lib/clickhouse/disks/s3_cache/</path>
                <max_size from_env="CLICKHOUSE_S3_CACHE_SIZE"/>
                <cache_on_write_operations>1</cache_on_write_operations>
            </s3_cache>
        </disks>
        <policies>
            <s3_cached>
                <volumes>
                    <main>
                        <disk>s3_cache</disk>
                    </main>
                </volumes>
            </s3_cached>
        </policies>
    </storage_configuration>

    <!--
      Make the cached-S3 policy the default for new MergeTree tables, so the
      migrations create events/source_entries/sessions on object storage with
      no per-table change. System log tables inherit it too; the local cache
      absorbs their reads. Switching an *existing* install is not automatic -
      tables created before this stay on the local `default` policy until their
      parts are moved (see docs/self-hosting.md).
    -->
    <merge_tree>
        <storage_policy>s3_cached</storage_policy>
    </merge_tree>
</clickhouse>
