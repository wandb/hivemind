        "displayType": "line",
        "select": [
          {"aggFn": "sum", "metricName": "redis.db.keys", "metricType": "gauge", "alias": "total keys", "valueExpression": "Value", "aggCondition": "", "aggConditionLanguage": "sql"},
          {"aggFn": "sum", "metricName": "redis.keys.expired", "metricType": "sum", "alias": "expired", "valueExpression": "Value", "aggCondition": "", "aggConditionLanguage": "sql"},
          {"aggFn": "sum", "metricName": "redis.keys.evicted", "metricType": "sum", "alias": "evicted", "valueExpression": "Value", "aggCondition": "", "aggConditionLanguage": "sql"}
        ],
        "where": "",
        "whereLanguage": "sql",
        "groupBy": "",
        "granularity": "auto"
      }
    },
    {
      "id": "redis-fragmentation", "x": 0, "y": 12, "w": 24, "h": 4,
      "config": {
        "name": "Memory fragmentation ratio",
        "source": "__METRICS_SOURCE_ID__",
        "displayType": "line",
        "select": [
          {"aggFn": "avg", "metricName": "redis.memory.fragmentation_ratio", "metricType": "gauge", "alias": "fragmentation", "valueExpression": "Value", "aggCondition": "", "aggConditionLanguage": "sql"}
        ],
        "where": "",
        "whereLanguage": "sql",
        "groupBy": "",
        "granularity": "auto"
      }
    }
  ]
}
